# ─────────────────────────────────────────────────────────────────────────────
# Memoire — Variáveis de ambiente
#
# Desenvolvimento: copiar para .env e preencher.
# Cloud Run: os valores marcados com [Secret Manager] devem ser criados como
#            secrets no GCP (ver comandos de setup abaixo).
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development              # production em Cloud Run
PORT=3001                         # Cloud Run força 8080 (definido no Dockerfile)

# ── Base de dados ─────────────────────────────────────────────────────────────
# Em Cloud Run: /data/db.sqlite (montado via GCS bucket)
DATABASE_PATH=./data/db.sqlite

# ── Autenticação ─────────────────────────────────────────────────────────────
# [Secret Manager: memoire-jwt-secret]
# OBRIGATÓRIO: mínimo 32 caracteres. Gerar: openssl rand -base64 48
JWT_SECRET=

# URL do frontend — usada no CORS para restringir origens aceites
# Desenvolvimento: http://localhost:5173 | Produção: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ── Immich ────────────────────────────────────────────────────────────────────
# URL interna do servidor Immich (ex: http://192.168.1.x:2283)
# Em Cloud Run com VPC: endereço acessível na rede privada
# [Secret Manager: memoire-immich-url]
IMMICH_URL=http://192.168.1.x:2283

# Chave de API read-only do Immich (Account Settings → API Keys)
# [Secret Manager: memoire-immich-key]
IMMICH_API_KEY=

# ── URL pública da aplicação (para meta tags OpenGraph) ───────────────────────
# Usada para construir URLs absolutas nas tags og:url e og:image.
# Se omitido, o servidor tenta inferir a partir do header Host do request.
PUBLIC_URL=https://yourdomain.com

# ── Sync automático de álbuns ─────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=60

# ── Admin ─────────────────────────────────────────────────────────────────────
# [Secret Manager: memoire-admin-email]
ADMIN_EMAIL=

# ── AI Layout (Gemini) ────────────────────────────────────────────────────────
# Chave da Google AI Studio (https://ai.dev) — obrigatória para AI Layout
# [Secret Manager: memoire-gemini-key]
GEMINI_API_KEY=
# Modelo Gemini a utilizar (opcional)
GEMINI_MODEL=gemini-2.0-flash
# Fotos por batch de análise (opcional, default 10)
AI_BATCH_SIZE=10
# Batches paralelos simultâneos (opcional, default 3)
AI_CONCURRENCY=3

# ── (build-time, apenas desenvolvimento local) ────────────────────────────────
# Em produção não são necessárias — Express serve o frontend no mesmo processo
VITE_API_URL=http://localhost:3001
VITE_IMMICH_URL=http://192.168.1.x:2283
